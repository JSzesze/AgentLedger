{
  "name": "agent-ledger",
  "version": "0.1.0",
  "description": "CLI to interpret GitHub issues into work orders, run Cursor, and post a paper trail on the issue",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JSzesze/AgentLedger.git"
  },
  "keywords": [
    "github",
    "issues",
    "cursor",
    "agent",
    "cli"
  ],
  "bin": {
    "agent-ledger": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@cursor/february": "^1.0.5",
    "commander": "^14.0.0",
    "dotenv": "^17.4.2",
    "execa": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
