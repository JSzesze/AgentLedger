# AgentLedger OpenClaw skill
# Copy values into OpenClaw config, gateway env, shell env, or sandbox env.

# Required for all commands except check (preflight) and list (repo only).
CURSOR_API_KEY=your_cursor_api_key_here
AGENT_LEDGER_REPO=/path/to/local/clone

# Optional for gh in headless / sandbox: GitHub API auth (gh also accepts GITHUB_TOKEN).
# GH_TOKEN=ghp_...

# Required for preview, run, interpret, and doctor.
AGENT_LEDGER_ISSUE=https://github.com/org/repo/issues/184

# Optional.
AGENT_LEDGER_PROMPT=Fix the issue described here
AGENT_LEDGER_CHECK=npm test
AGENT_LEDGER_CLARITY=auto
AGENT_LEDGER_LIMIT=50
AGENT_LEDGER_CURSOR_MODEL=composer-2

# Default is false, which adds --no-post. Set true only when comments should be posted.
AGENT_LEDGER_POST=false
